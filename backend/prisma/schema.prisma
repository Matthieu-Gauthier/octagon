generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id
  email         String         @unique
  username      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  bets          Bet[]
  leagues       LeagueMember[]
  leaguesOwned  League[]
  survivorPicks SurvivorPick[]

  @@map("users")
}

model League {
  id              String         @id @default(uuid())
  name            String
  code            String         @unique
  survivorEnabled Boolean        @default(false)
  isArchived      Boolean        @default(false)
  createdAt       DateTime       @default(now())
  adminId         String
  scoringSettings Json           @default("{\"round\": 5, \"method\": 5, \"winner\": 10}")
  bets            Bet[]
  members         LeagueMember[]
  atouts          Atout[]
  admin           User           @relation(fields: [adminId], references: [id])
  survivorPicks   SurvivorPick[]

  @@map("leagues")
}

model Atout {
  id             String   @id @default(uuid())
  leagueId       String
  eventId        String
  fightId        String
  type           String
  playedByUserId String
  playedByName   String
  targetUserId   String?
  targetUserName String?
  playedAt       DateTime @default(now())
  league         League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, eventId, playedByUserId])
  @@map("atouts")
}

model LeagueMember {
  id       String   @id @default(uuid())
  leagueId String
  userId   String
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())
  league   League   @relation(fields: [leagueId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([leagueId, userId])
  @@map("league_members")
}

model Event {
  id              String    @id
  name            String
  date            DateTime
  location        String
  status          String
  mainCardStartAt DateTime?
  prelimsStartAt  DateTime?
  eventImg        String?
  ufcstatsId      String?
  fights          Fight[]

  @@map("events")
}

model Fighter {
  id                     String  @id
  name                   String
  wins                   Int?
  losses                 Int?
  draws                  Int?
  noContests             Int?
  winsByKo               Int?
  winsBySub              Int?
  winsByDec              Int?
  height                 String?
  weight                 String?
  reach                  String?
  stance                 String?
  sigStrikesLandedPerMin Float?
  takedownAvg            Float?
  imagePath              String?
  hometown               String?
  recentForm             Json?
  ufcstatsId             String?
  age                    Int?
  nickname               String?
  rankingPosition        Int?
  isChampion             Boolean?
  fightsA                Fight[] @relation("FighterA")
  fightsB                Fight[] @relation("FighterB")

  @@map("fighters")
}

model Fight {
  id            String         @id
  eventId       String
  fighterAId    String
  fighterBId    String
  division      String
  rounds        Int
  isMainEvent   Boolean        @default(false)
  isCoMainEvent Boolean        @default(false)
  isMainCard    Boolean        @default(true)
  isPrelim      Boolean        @default(false)
  status        String         @default("SCHEDULED")
  winnerId      String?
  method        String?
  round         Int?
  time          String?
  order         Int            @default(0)
  ufcstatsId    String?
  bets          Bet[]
  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  fighterA      Fighter        @relation("FighterA", fields: [fighterAId], references: [id])
  fighterB      Fighter        @relation("FighterB", fields: [fighterBId], references: [id])
  survivorPicks SurvivorPick[]

  @@map("fights")
}

model Bet {
  id        String   @id @default(uuid())
  leagueId  String
  userId    String
  fightId   String
  winnerId  String
  method    String?
  round     Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  fight     Fight    @relation(fields: [fightId], references: [id], onDelete: Cascade)
  league    League   @relation(fields: [leagueId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([leagueId, userId, fightId])
  @@map("bets")
}

model SurvivorPick {
  id        String   @id @default(uuid())
  leagueId  String
  userId    String
  fightId   String
  eventId   String
  fighterId String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  fight     Fight    @relation(fields: [fightId], references: [id], onDelete: Cascade)
  league    League   @relation(fields: [leagueId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([leagueId, userId, fightId])
  @@map("survivor_picks")
}
